+/// True for v32i8 V1+zero shuffles whose retained bytes are exactly an
+/// in-lane identity-or-zero pattern at complete i16 pairs (VPBLENDW shape).
+/// Covers sparse variants A/B/C without hardcoding byte positions.
+static bool isZmovlStyleTruncLaneShuffle(ArrayRef<int> Mask, unsigned Base) {
+  auto IsZero = [&](int M) { return M >= 32; };
+  auto IsIdentity = [&](unsigned I, int M) {
+    return !IsZero(M) && M >= 0 && M == (int)I;
+  };
+
+  // A lane that is entirely identity is a copy, not zmovl truncation.
+  if (llvm::all_of(llvm::seq<unsigned>(0, 16), [&](unsigned I) {
+        return IsIdentity(Base + I, Mask[Base + I]);
+      }))
+    return false;
+
+  bool HasZero = false;
+  for (unsigned I = 0; I < 16; ++I) {
+    if (IsZero(Mask[Base + I]))
+      HasZero = true;
+  }
+  if (!HasZero)
+    return false;
+
+  unsigned LastIdentity = 0;
+  while (LastIdentity < 16 && IsIdentity(Base + LastIdentity,
+                                         Mask[Base + LastIdentity]))
+    ++LastIdentity;
+  if (LastIdentity == 0)
+    return false;
+
+  for (unsigned I = LastIdentity; I < 16; ++I)
+    if (!IsZero(Mask[Base + I]))
+      return false;
+  return true;
+}
+
+static bool isZmovlStyleTruncLanePSHUFB(ArrayRef<int> Mask, unsigned Base) {
+  auto IsZero = [](int M) { return M == SM_SentinelZero; };
+  auto IsIdentity = [&](unsigned I, int M) {
+    return !IsZero(M) && M >= 0 && M == (int)I;
+  };
+
+  if (llvm::all_of(llvm::seq<unsigned>(0, 16), [&](unsigned I) {
+        return IsIdentity(Base + I, Mask[Base + I]);
+      }))
+    return false;
+
+  bool HasZero = false;
+  for (unsigned I = 0; I < 16; ++I) {
+    if (IsZero(Mask[Base + I]))
+      HasZero = true;
+  }
+  if (!HasZero)
+    return false;
+
+  unsigned LastIdentity = 0;
+  while (LastIdentity < 16 && IsIdentity(Base + LastIdentity,
+                                         Mask[Base + LastIdentity]))
+    ++LastIdentity;
+  if (LastIdentity == 0)
+    return false;
+
+  for (unsigned I = LastIdentity; I < 16; ++I)
+    if (!IsZero(Mask[Base + I]))
+      return false;
+  return true;
+}
+
+static bool isInLaneIdentityOrZeroBytePairShuffleMask(ArrayRef<int> Mask,
+                                                      bool V2IsZero) {
+  if (Mask.size() != 32 || !V2IsZero)
+    return false;
+
+  auto isZero = [&](int M) { return M >= 32; };
+  auto isIdentity = [&](unsigned I, int M) {
+    return !isZero(M) && M >= 0 && M == (int)I;
+  };
+
+  bool AnyRetained = false;
+  for (unsigned Lane = 0; Lane < 2; ++Lane) {
+    unsigned Base = Lane * 16;
+    // Exclude VZEXT_MOVL / vzmovl-style contiguous prefix+zero lanes.
+    if (isZmovlStyleTruncLaneShuffle(Mask, Base))
+      return false;
+    for (unsigned W = 0; W < 8; ++W) {
+      unsigned B0 = Base + 2 * W;
+      unsigned B1 = B0 + 1;
+      int M0 = Mask[B0], M1 = Mask[B1];
+      if (M0 < 0 || M1 < 0)
+        return false;
+      if (isZero(M0) != isZero(M1))
+        return false;
+      if (isIdentity(B0, M0) != isIdentity(B1, M1))
+        return false;
+      if (isIdentity(B0, M0))
+        AnyRetained = true;
+    }
+    for (unsigned I = 0; I < 16; ++I) {
+      unsigned G = Base + I;
+      int M = Mask[G];
+      if (M < 0)
+        return false;
+      if (isZero(M))
+        continue;
+      if (M != (int)G)
+        return false;
+    }
+  }
+  return AnyRetained;
+}
+
+/// Same structural class as above, applied to a decoded v32i8 PSHUFB mask.
+static bool isInLaneIdentityOrZeroBytePairPSHUFBMask(ArrayRef<int> Mask) {
+  if (Mask.size() != 32)
+    return false;
+
+  auto isZero = [](int M) { return M == SM_SentinelZero; };
+  auto isIdentity = [&](unsigned I, int M) {
+    return !isZero(M) && M >= 0 && M == (int)I;
+  };
+
+  bool AnyRetained = false;
+  for (unsigned Lane = 0; Lane < 2; ++Lane) {
+    unsigned Base = Lane * 16;
+    if (isZmovlStyleTruncLanePSHUFB(Mask, Base))
+      return false;
+    for (unsigned W = 0; W < 8; ++W) {
+      unsigned B0 = Base + 2 * W;
+      unsigned B1 = B0 + 1;
+      int M0 = Mask[B0], M1 = Mask[B1];
+      if (M0 == SM_SentinelUndef || M1 == SM_SentinelUndef)
+        return false;
+      if (isZero(M0) != isZero(M1))
+        return false;
+      if (isIdentity(B0, M0) != isIdentity(B1, M1))
+        return false;
+      if (isIdentity(B0, M0))
+        AnyRetained = true;
+    }
+    for (unsigned I = 0; I < 16; ++I) {
+      unsigned G = Base + I;
+      int M = Mask[G];
+      if (M == SM_SentinelUndef)
+        return false;
+      if (isZero(M))
+        continue;
+      if (M != (int)G)
+        return false;
+    }
+  }
+  return AnyRetained;
+}
+
+/// Sparse zero-fill subset (variants A/B/C): identity-or-zero with multiple
+/// cleared i16 pairs per lane, excluding partial-word intrinsic masks.
+static bool isSparseInLaneIdentityOrZeroBytePairPSHUFBMask(
+    ArrayRef<int> Mask) {
+  if (!isInLaneIdentityOrZeroBytePairPSHUFBMask(Mask))
+    return false;
+
+  for (unsigned Lane = 0; Lane < 2; ++Lane) {
+    unsigned Base = Lane * 16;
+    unsigned ZeroWordPairs = 0;
+    for (unsigned W = 0; W < 8; ++W) {
+      if (Mask[Base + 2 * W] == SM_SentinelZero &&
+          Mask[Base + 2 * W + 1] == SM_SentinelZero)
+        ++ZeroWordPairs;
+    }
+    if (ZeroWordPairs < 2)
+      return false;
+  }
+  return true;
+}
