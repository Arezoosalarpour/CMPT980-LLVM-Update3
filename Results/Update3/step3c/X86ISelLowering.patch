+/// Return true if \p Mask can be lowered with a single PSHUFB using \p V1/\p V2.
+/// Mirrors the failure checks in lowerShuffleWithPSHUFB without creating DAG nodes.
+static bool canLowerShuffleWithPSHUFB(MVT VT, ArrayRef<int> Mask,
+                                      const APInt &Zeroable, bool V2IsZero) {
+  int Size = Mask.size();
+  int LaneSize = 128 / VT.getScalarSizeInBits();
+  const int NumBytes = VT.getSizeInBits() / 8;
+  const int NumEltBytes = VT.getScalarSizeInBits() / 8;
+
+  bool UsesV1 = false;
+  bool UsesV2 = false;
+  for (int i = 0; i < NumBytes; ++i) {
+    int M = Mask[i / NumEltBytes];
+    if (M < 0)
+      continue;
+    if (Zeroable[i / NumEltBytes] || (M >= Size && V2IsZero))
+      continue;
+
+    bool FromV2 = M >= Size;
+    if (FromV2) {
+      if (UsesV1)
+        return false;
+      UsesV2 = true;
+    } else {
+      if (UsesV2)
+        return false;
+      UsesV1 = true;
+    }
+    M %= Size;
+
+    if ((M / LaneSize) != ((i / NumEltBytes) / LaneSize))
+      return false;
+  }
+  return UsesV1 || UsesV2;
+}
+
+/// Mark lanes selecting from a zero V2 as zeroable for PSHUFB lowering.
+static APInt getPSHUFBZeroable(ArrayRef<int> Mask, const APInt &Zeroable,
+                               bool V2IsZero) {
+  APInt Result = Zeroable;
+  if (!V2IsZero)
+    return Result;
+  for (int i = 0, Size = (int)Mask.size(); i < Size; ++i)
+    if (Mask[i] >= Size)
+      Result.setBit(i);
+  return Result;
+}
